{
  "baseBranch": "main",
  "enableLlmRules": true,
  "rules": {
    "deprecated-class": {
      "enabled": true,
      "severity": "error",
      "options": {
        "classes": [
          {
            "name": "TextSize",
            "source": "@components/Typography/Text",
            "replacement": "use Span size prop from @ui/Typography/Text"
          },
          {
            "name": "TextWeight",
            "source": "@components/Typography/Text",
            "replacement": "use Span weight prop from @ui/Typography/Text"
          },
          {
            "name": "TextUseTooltip",
            "source": "@components/Typography/Text",
            "replacement": "use Span withTooltip prop from @ui/Typography/Text"
          },
          {
            "name": "Text",
            "source": "@components/Typography/Text",
            "replacement": "use P, Span, Label, or Header from @ui/Typography/Text"
          },
          {
            "name": "DeprecatedTextWithTooltip",
            "source": "@components/Typography/Text",
            "replacement": "use Span with withTooltip prop from @ui/Typography/Text"
          }
        ]
      }
    },
    "thin-css-class-text": {
      "enabled": true,
      "severity": "warning",
      "options": {
        "typographyProperties": [
          "font-size",
          "font-weight",
          "color",
          "text-align",
          "white-space",
          "overflow",
          "text-overflow",
          "padding-block",
          "padding-block-start",
          "padding-block-end"
        ],
        "maxProperties": 2,
        "component": "Span",
        "componentSource": "@ui/Typography/Text"
      }
    },
    "no-client-side-calculations": {
      "enabled": true,
      "severity": "warning",
      "options": {
        "maxAddedLines": 3000,
        "filePatterns": [
          "**/TaxPaymentsTable.tsx"
        ]
      }
    },
    "no-css-classname-concatenation": {
      "enabled": true,
      "severity": "error",
      "options": {
        "excludePatterns": [
          {
            "file": "src/components/DataTable/DataTable.tsx",
            "pattern": "Layer__UI__Table-Cell"
          }
        ]
      }
    },
    "i18n-key-in-manifest": {
      "enabled": true,
      "severity": "error",
      "options": {
        "localesPath": "src/assets/locales",
        "primaryLocale": "en-US",
        "additionalLocales": [
          "fr-CA"
        ],
        "translationFunctions": [
          "translationKey",
          "t"
        ]
      }
    },
    "simple-component-styling": {
      "enabled": true,
      "severity": "warning",
      "options": {}
    },
    "no-ternary-responsive-containers": {
      "enabled": true,
      "severity": "warning",
      "options": {}
    }
  }
}