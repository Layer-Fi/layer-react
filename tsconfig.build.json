{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationMap": true,
    "incremental": true,
    "tsBuildInfoFile": "./dist/.cache/tsconfig.build.tsbuildinfo",
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "src/msw/**/*"
  ]
}
